---
import '@fontsource/inter';
import '../styles/global.css';
import { version } from '../../package.json';
---
<!doctype html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Adopte un Motard</title>
	</head>
	<body class="font-sans antialiased text-deep-charcoal bg-paper selection:bg-electric-cyan/50">
		<slot />
		
		<!-- 🎖️ Version Badge -->
		<div class="fixed bottom-4 left-4 z-50 pointer-events-none">
			<span class="text-[10px] font-mono text-zinc-500 bg-zinc-900/50 backdrop-blur-sm px-2 py-1 rounded-full border border-zinc-800/50">
				v{version}
			</span>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
