---
import '@fontsource/inter';
import '../styles/global.css';
import { Navbar } from '../components/Navbar';
import { ScrollToTop } from '../components/ui/ScrollToTop';
import { YouTubeWidget } from '../components/ui/YouTubeWidget';
import { CoursePreview } from '../components/ui/CoursePreview';
import { version } from '../../package.json';
---
<!doctype html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Adopte un Motard</title>
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				if (theme !== 'dark') {
					document.documentElement.classList.add('light');
				}
			})();
		</script>
	</head>
	<body class="font-sans antialiased text-text-primary bg-bg selection:bg-accent/30 overflow-x-hidden">
		<Navbar client:load />
		<slot />
		<ScrollToTop client:load />
		<YouTubeWidget client:load />
		<CoursePreview client:load />
		
		<!-- 🎖️ Version Badge -->
		<div class="fixed bottom-4 left-4 z-50 pointer-events-none">
			<span class="text-[10px] font-bold font-mono text-text-primary/40 bg-white/5 backdrop-blur-sm px-2 py-1 rounded-full border border-white/10 shadow-sm">
				v{version}
			</span>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
