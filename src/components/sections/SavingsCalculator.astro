---
import { ComparisonTool } from '../ui/ComparisonTool';
import { FadeIn } from '../ui/FadeIn';
---

<section id="rentabilite" class="py-24 md:py-32 bg-bg overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mb-16">
      <FadeIn client:visible>
        <h2 class="text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Maîtrise & Rentabilité</h2>
        <p class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter leading-none mb-8">
          Calculez votre <span class="text-accent">liberté financière.</span>
        </p>
        <p class="text-text-secondary text-lg max-w-xl">
          Le passage à l'électrique n'est pas qu'une question de sensations. C'est un choix mathématique qui transforme vos dépenses contraintes en épargne réelle.
        </p>
      </FadeIn>
    </div>

    <FadeIn client:visible delay={0.2}>
      <ComparisonTool client:load />
    </FadeIn>

    <div class="mt-16 text-center">
      <p class="text-[10px] text-text-secondary font-black uppercase tracking-[0.4em] opacity-30">
        Calculs basés sur les tarifs énergétiques moyens 2024 • Zero SR/F vs Roadster 600cc
      </p>
    </div>
  </div>
</section>
