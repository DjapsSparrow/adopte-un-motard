---
import { Button } from '../ui/Button';
import { FadeIn } from '../ui/FadeIn';
import { ElectricText } from '../ui/electric-text';
import { ArrowDown } from 'lucide-react';
---

<section class="relative pt-32 pb-40 md:pt-48 md:pb-64 overflow-hidden flex flex-col items-center justify-center min-h-screen bg-bg">
  {/* Luminous Arc (Glow) Effect at the bottom */}
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[150%] h-[300px] bg-[radial-gradient(ellipse_at_top,_var(--color-accent)_0%,_transparent_70%)] opacity-20 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-accent to-transparent opacity-50"></div>

  <div class="container mx-auto px-6 max-w-5xl text-center relative z-10">
    <FadeIn client:visible>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent/20 bg-accent/5 text-accent text-xs font-bold tracking-widest uppercase mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Technologie Antigravity v1.6
      </div>
    </FadeIn>

    <FadeIn client:visible delay={0.1}>
      <h1 class="text-5xl md:text-[80px] font-black leading-[0.9] text-white mb-8 tracking-tighter uppercase italic">
        L'apesanteur, <br />
        <span class="text-accent text-glow">maintenant sur deux roues.</span>
      </h1>
    </FadeIn>

    <FadeIn client:visible delay={0.2}>
      <p class="text-lg md:text-[24px] text-text-secondary leading-relaxed max-w-3xl mx-auto mb-16 font-medium">
        Passez à l'ère électrique avec une <span class="text-white">précision chirurgicale</span> et une puissance instantanée.
      </p>
    </FadeIn>

    <FadeIn client:visible delay={0.3} className="w-full max-w-md mx-auto">
      <div class="relative group">
        <input 
          type="text" 
          placeholder="Entrez votre ville pour un essai..." 
          class="w-full bg-surface border border-white/10 rounded-2xl py-5 px-6 text-white placeholder:text-text-secondary focus:outline-none focus:border-accent/50 transition-all shadow-2xl"
        />
        <button class="absolute right-2 top-2 bottom-2 bg-accent text-bg px-6 rounded-xl font-black text-sm hover:scale-105 transition-transform active:scale-95">
          RÉSERVER
        </button>
      </div>
      <p class="mt-4 text-[10px] text-text-secondary uppercase tracking-[0.2em] font-bold opacity-50">
        Aucun engagement • Disponibilité immédiate
      </p>
    </FadeIn>
  </div>
</section>
