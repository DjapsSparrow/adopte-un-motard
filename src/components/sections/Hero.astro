---
import { Button } from '../ui/Button';
import { FadeIn } from '../ui/FadeIn';
import { ElectricText } from '../ui/electric-text';
import { ArrowDown } from 'lucide-react';
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-32 overflow-hidden flex flex-col items-center justify-center min-h-[90vh] bg-deep-charcoal">
  {/* Background Image with Overlay */}
  <div class="absolute inset-0 z-0">
    <img 
      src="/src/assets/hero-bg.jpg" 
      alt="Motard en virage" 
      class="w-full h-full object-cover opacity-60" 
    />
    <div class="absolute inset-0 bg-gradient-to-b from-deep-charcoal/80 via-deep-charcoal/40 to-deep-charcoal/80"></div>
  </div>

  <div class="container mx-auto px-6 max-w-4xl text-center relative z-10">
    <FadeIn client:visible>
      <img src="/logo.png" alt="Adopte Un Motard Logo" class="h-48 md:h-64 mx-auto mb-10 object-contain drop-shadow-2xl brightness-0 invert" />
    </FadeIn>

    <FadeIn client:visible delay={0.1}>
      <h1 class="text-4xl md:text-[60px] font-black leading-tight text-white mb-8 tracking-tight">
        <ElectricText client:load text="Passer à la moto électrique :" /> <br />
        <span class="text-electric-cyan">Arrêtez de fantasmer</span>, apprenez à la vivre.
      </h1>
    </FadeIn>

    <FadeIn client:visible delay={0.2}>
      <p class="text-lg md:text-[22px] text-paper/90 leading-relaxed max-w-3xl mx-auto mb-12">
        <strong>5 ans d’expérience au quotidien</strong> condensés en une formation ultra-complète pour décider, choisir et rouler sereinement. 
        Sans discours de vendeur, <span class="underline decoration-electric-cyan decoration-4 underline-offset-4">juste la réalité du bitume</span>.
      </p>
    </FadeIn>

    <FadeIn client:visible delay={0.3} className="flex flex-col sm:flex-row items-center justify-center gap-6">
      <Button href="#programme" client:load className="w-full sm:w-auto text-lg py-5 px-10">
        Rejoindre la formation
      </Button>
      <Button href="#programme" variant="secondary" client:load className="w-full sm:w-auto text-lg py-5 px-10 text-white border-white/20 hover:bg-white/10" icon={ArrowDown}>
        Voir le programme
      </Button>
    </FadeIn>
  </div>
</section>
