---
import { FadeIn } from '../ui/FadeIn';
import { Button } from '../ui/Button';
import { BadgeCheck, Clock, PiggyBank } from 'lucide-react';
---

<section id="tarifs" class="py-24 md:py-32 bg-bg">
  <div class="container mx-auto px-6 max-w-5xl">
    <FadeIn client:visible>
      <div class="text-center mb-20">
        <h2 class="text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Investissement intelligent</h2>
        <p class="text-3xl md:text-5xl font-black text-text-primary italic uppercase tracking-tighter">
          Un prix transparent. <br/> <span class="text-accent">Une maîtrise totale.</span>
        </p>
      </div>
    </FadeIn>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <FadeIn client:visible delay={0.1} className="bg-surface p-10 rounded-[24px] border border-white/5 relative group hover:border-accent/30 transition-all">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-accent/10 mb-8 text-accent">
          <BadgeCheck size={28} />
        </div>
        <h3 class="text-xl font-black text-text-primary mb-4 uppercase italic">La Fiabilité</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Données vérifiées et tests réels sur des milliers de kilomètres. Pas de théorie, <span class="text-text-primary italic">juste la réalité.</span>
        </p>
      </FadeIn>

      <FadeIn client:visible delay={0.2} className="bg-surface p-10 rounded-[24px] border border-white/5 relative group hover:border-accent/30 transition-all">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-accent/10 mb-8 text-accent">
          <Clock size={28} />
        </div>
        <h3 class="text-xl font-black text-text-primary mb-4 uppercase italic">Le Gain de temps</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Plus de <span class="text-text-primary italic">3 heures de conseils</span> stratégiques pour éviter tous les pièges.
        </p>
      </FadeIn>

      <FadeIn client:visible delay={0.3} className="bg-surface p-10 rounded-[24px] border border-accent/20 relative group hover:border-accent/50 transition-all shadow-[0_0_30px_rgba(0,163,255,0.05)]">
        <div class="absolute top-0 right-0 p-4">
          <div class="h-2 w-2 rounded-full bg-accent animate-pulse"></div>
        </div>
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-accent/20 mb-8 text-accent">
          <PiggyBank size={28} />
        </div>
        <h3 class="text-xl font-black text-text-primary mb-4 uppercase italic">Rentabilité</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          La formation coûte le prix d'un plein... pour éviter une erreur de casting à <span class="text-text-primary italic">15 000 €</span>.
        </p>
      </FadeIn>
    </div>

    <FadeIn client:visible delay={0.4}>
      <div class="bg-gradient-to-b from-surface to-bg p-12 rounded-[32px] border border-accent/30 text-center relative overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-1 bg-accent/50"></div>
        
        <div class="mb-6">
          <span class="text-xs font-black uppercase tracking-[0.4em] text-accent">Accès à vie • Mise à jour régulières</span>
        </div>
        
        <div class="flex items-baseline justify-center gap-2 mb-10">
          <span class="text-7xl md:text-9xl font-black text-text-primary tracking-tighter italic">29</span>
          <span class="text-4xl md:text-5xl font-black text-accent italic">€</span>
        </div>

        <div class="flex flex-col items-center gap-6">
          <Button 
            href="https://ecole.fudoshin.solutions/offers/aab1d65b-e96b-49a2-b054-de94398f7f7b" 
            target="_blank"
            client:load 
            className="text-xl py-6 px-16 w-full sm:w-auto"
          >
            Je rejoins la formation
          </Button>
          
          <p class="text-[10px] text-text-secondary font-black uppercase tracking-widest opacity-50">
            Paiement sécurisé • Accès immédiat après validation
          </p>
        </div>
      </div>
    </FadeIn>
  </div>
</section>
