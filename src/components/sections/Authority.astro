---
import { FadeIn } from '../ui/FadeIn';
import { ShieldCheck } from 'lucide-react';
---

<section class="py-24 md:py-32 bg-paper">
  <div class="container mx-auto px-6 max-w-5xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <FadeIn className="order-2 md:order-1">
        <div class="rounded-2xl overflow-hidden shadow-2xl relative aspect-[4/5] md:aspect-auto md:h-full">
          <img 
            src="/moto-1.jpg" 
            alt="Moto électrique en conditions réelles" 
            class="absolute inset-0 w-full h-full object-cover"
            onError={(e) => {
              // Fallback if image doesn't exist yet
              (e.target as HTMLImageElement).src = "https://placehold.co/800x1000/3D4144/FFFFFF?text=Photo+Moto";
            }}
          />
        </div>
      </FadeIn>

      <div class="order-1 md:order-2">
        <FadeIn delay={0.1}>
          <h2 class="text-3xl md:text-[40px] font-bold text-deep-charcoal mb-6 leading-tight">
            Ma promesse : <br/>
            <span class="text-electric-cyan text-[44px]">Le raccourci vers la liberté branchée.</span>
          </h2>
        </FadeIn>

        <FadeIn delay={0.2}>
          <p class="text-[18px] text-carbon-grey leading-relaxed mb-6">
            Je roule en moto électrique depuis plus de 5 ans, notamment en Zero SR/F, au quotidien. <strong>Pas pour faire une vidéo "test", mais pour vivre avec.</strong>
          </p>
          <p class="text-[18px] text-carbon-grey leading-relaxed mb-10">
            J'ai connu les doutes, les erreurs de débutant, les galères de recharge sous la pluie, mais aussi les sensations incroyables du couple instantané.
          </p>
        </FadeIn>

        <FadeIn delay={0.3}>
          <div class="flex items-start gap-4 p-6 bg-white rounded-2xl border-l-4 border-electric-cyan shadow-sm">
            <ShieldCheck className="w-8 h-8 text-electric-cyan flex-shrink-0" />
            <div>
              <p class="text-[20px] font-bold text-deep-charcoal mb-1">L'engagement</p>
              <p class="text-carbon-grey italic">
                "Cette formation existe pour une seule raison : vous éviter de vous lancer à l’aveugle."
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </div>
</section>
