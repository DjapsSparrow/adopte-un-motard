---
import { Image } from 'astro:assets';
import motoLiberte from '../../assets/images/moto-liberte.jpg';
import { FadeIn } from '../ui/FadeIn';
import { ShieldCheck } from 'lucide-react';
---

<section id="promesse" class="py-24 md:py-32 bg-bg relative">
  <div class="container mx-auto px-6 max-w-5xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <FadeIn client:visible className="order-2 md:order-1 relative">
        <!-- Effet de lueur en arrière-plan -->
        <div class="absolute -inset-4 bg-accent/20 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
        
        <div class="relative group">
          <!-- Bordure décorative décalée -->
          <div class="absolute inset-0 border-2 border-accent/30 rounded-[32px] translate-x-3 translate-y-3 -rotate-3 transition-transform duration-500 group-hover:rotate-0 group-hover:translate-x-0 group-hover:translate-y-0"></div>
          
          <!-- Conteneur Image Principal -->
          <div class="relative rounded-[32px] overflow-hidden border border-white/10 shadow-2xl aspect-[3/4] bg-surface-lighter -rotate-1 group-hover:rotate-0 transition-all duration-500 ease-out">
            <Image 
              src={motoLiberte} 
              alt="Ma vie en moto électrique - Adopte un Motard" 
              class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-700 ease-out"
              quality="mid"
              width={800}
              height={1067}
            />
            
            <!-- Overlay de protection/style -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60"></div>
            
            <!-- Badge 100% Vécu -->
            <div class="absolute bottom-6 left-6 right-6">
              <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/90 backdrop-blur-md rounded-full shadow-lg">
                <div class="w-2 h-2 rounded-full bg-black animate-pulse"></div>
                <span class="text-black text-xs font-black uppercase tracking-widest">100% Vécu</span>
              </div>
            </div>
          </div>

          <!-- Petit sticker technique décalé -->
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-white dark:bg-zinc-900 rounded-2xl shadow-xl border border-accent/20 flex items-center justify-center -rotate-12 group-hover:rotate-0 transition-transform duration-500">
             <ShieldCheck className="w-10 h-10 text-accent" />
          </div>
        </div>
      </FadeIn>

      <div class="order-1 md:order-2">
        <FadeIn client:visible delay={0.1}>
          <h2 class="text-3xl md:text-[50px] font-black text-text-primary mb-8 leading-[0.95] uppercase italic tracking-tighter">
            Ma promesse : <br/>
            <span class="text-accent text-glow">Le raccourci vers la liberté branchée.</span>
          </h2>
        </FadeIn>

        <FadeIn client:visible delay={0.2}>
          <p class="text-[18px] text-text-secondary leading-relaxed mb-6">
            Je roule en moto électrique depuis <span class="text-text-primary font-bold">plus de 5 ans</span>, notamment en Zero SR/F, au quotidien. <span class="text-text-primary">Pas pour faire une vidéo "test", mais pour vivre avec.</span>
          </p>
          <p class="text-[18px] text-text-secondary leading-relaxed mb-10">
            J'ai connu les doutes, les erreurs de débutant, les galères de recharge sous la pluie, mais aussi les sensations incroyables du couple instantané.
          </p>
        </FadeIn>

        <FadeIn client:visible delay={0.3}>
          <div class="flex items-start gap-4 p-8 bg-surface rounded-[24px] border border-white/5 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 blur-3xl rounded-full translate-x-1/2 -translate-y-1/2"></div>
            <ShieldCheck className="w-8 h-8 text-accent flex-shrink-0" />
            <div class="relative z-10">
              <p class="text-xl font-black text-text-primary mb-2 italic uppercase">L'engagement</p>
              <p class="text-text-secondary italic">
                "Cette formation existe pour une seule raison&nbsp;: vous éviter de vous lancer à l’aveugle."
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </div>
</section>
