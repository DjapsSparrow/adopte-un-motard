---
import { Button } from '../ui/Button';
import { FadeIn } from '../ui/FadeIn';
import { ShieldCheck, Video, CheckSquare } from 'lucide-react';
---

<section class="py-24 md:py-32 bg-bg relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom,_var(--color-accent)_0%,_transparent_50%)] opacity-10 pointer-events-none"></div>
  
  <div class="container mx-auto px-6 max-w-4xl text-center relative z-10">
    <FadeIn client:visible>
      <h2 class="text-4xl md:text-[70px] font-black text-white mb-8 leading-[0.9] italic uppercase tracking-tighter">
        Sautez le pas avec <br /> <span class="text-accent text-glow">certitude.</span>
      </h2>
    </FadeIn>

    <FadeIn client:visible delay={0.1}>
      <blockquote class="text-[20px] md:text-[24px] text-text-secondary font-medium italic max-w-3xl mx-auto mb-16 leading-relaxed">
        "La formation ne s'arrête pas au dernier slide, elle se poursuit à chaque virage que nous prendrons désormais en silence."
      </blockquote>
    </FadeIn>

    <FadeIn client:visible delay={0.2} className="flex flex-col items-center justify-center">
      <Button href="#tarifs" client:load className="text-xl py-6 px-12 mb-10 w-full sm:w-auto">
        J'ACCÈDE À LA FORMATION MAINTENANT
      </Button>

      <div class="flex flex-wrap justify-center items-center gap-6 text-text-secondary text-[10px] font-black uppercase tracking-[0.2em] opacity-60">
        <div class="flex items-center gap-2">
          <div class="h-1 w-1 rounded-full bg-accent"></div>
          <span>Accès immédiat</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="h-1 w-1 rounded-full bg-accent"></div>
          <span>Vidéos + Quiz de validation</span>
        </div>
      </div>
    </FadeIn>
  </div>
</section>
