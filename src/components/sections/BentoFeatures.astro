---
import { 
  Zap, 
  Target, 
  Activity, 
  Wind, 
  BatteryCharging, 
  Map, 
  Wrench, 
  Headphones, 
  Scale,
  Brain
} from 'lucide-react';
import { FadeIn } from '../ui/FadeIn';

const modules = [
  {
    title: "Le Choc des Réalités",
    desc: "Démystifier l'ADN de ces machines sans fantasmes ni peurs.",
    icon: Brain
  },
  {
    title: "L'Audit de vos Besoins",
    desc: "Analyser votre usage réel (pas votre fantasme) pour choisir la bonne bécane.",
    icon: Target
  },
  {
    title: "L'Électricité sans jargon",
    desc: "Comprendre les kW, kWh et les prises sans être ingénieur.",
    icon: Zap
  },
  {
    title: "Pilotage & Sensations",
    desc: "Dompter la poussée linéaire et maîtriser la régénération.",
    icon: Activity
  },
  {
    title: "Efficience & Météo",
    desc: "Jouer avec les éléments (vent, froid) pour optimiser vos trajets.",
    icon: Wind
  },
  {
    title: "La Recharge de A à Z",
    desc: "Gérer sa batterie à la maison et réussir ses premiers road-trips.",
    icon: BatteryCharging
  },
  {
    title: "Road-trips & Logistique",
    desc: "Planification et gestion du réseau de charge en conditions réelles.",
    icon: Map
  },
  {
    title: "Entretien & Fiabilité",
    desc: "Ce qui disparaît (vidanges) et ce qu'il faut surveiller (cellules, mises à jour).",
    icon: Wrench
  },
  {
    title: "Équipement Spécifique",
    desc: "Gérer le confort acoustique et thermique du motard électrique.",
    icon: Headphones
  },
  {
    title: "Le Verdict",
    desc: "Est-ce fait pour vous (ou faut-il attendre) ?",
    icon: Scale
  }
];
---

<section class="py-24 md:py-32 bg-bg relative overflow-hidden" id="programme">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mb-16">
      <h2 class="text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Le programme complet</h2>
      <p class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
        10 modules pour devenir <span class="text-accent">un motard augmenté.</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
      {modules.map((m, i) => (
        <FadeIn client:visible delay={i * 0.05} className="group relative overflow-hidden rounded-[24px] border border-white/5 bg-surface p-6 transition-all hover:border-accent/30 flex flex-col justify-between min-h-[220px]">
          <div class="relative z-10">
            <div class="h-10 w-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent mb-6 group-hover:scale-110 transition-transform">
              <m.icon size={20} />
            </div>
            <h3 class="text-lg font-black text-white mb-2 uppercase italic leading-tight">{m.title}</h3>
            <p class="text-xs text-text-secondary leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              {m.desc}
            </p>
          </div>
          <div class="text-[40px] font-black text-white/5 absolute -bottom-2 -right-2 italic select-none">
            {String(i + 1).padStart(2, '0')}
          </div>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
